@inherits LayoutComponentBase

<MudThemeProvider Theme="_lakkaTheme" />
<MudDialogProvider />
<MudSnackbarProvider />

<!-- Üst Bilgi Şeridi -->
<div class="lakka-announcement">Tüm siparişlerde ücretsiz kargo ve 30 gün iade garantisi</div>

<MudLayout>
    <MudAppBar Elevation="0" Fixed="true" Class="lakka-appbar" Style="top:36px;height:auto;">
        <div style="width:100%;display:flex;align-items:center;padding:10px 28px;gap:22px;">

            <!-- SOL: Logo -->
            <a href="/" style="display:flex;align-items:center;flex-shrink:0;text-decoration:none;">
                <img src="images/lakka-logo.jpg" alt="LAKKA Mobilya"
                     style="height:56px;width:auto;object-fit:contain;display:block;" />
            </a>

            <!-- ORTA: Mega Menü (krem şerit · beyaz yazı · hover ile mega panel açılır) -->
            <nav class="lakka-nav-bar d-none d-md-flex"
                 style="flex:1 1 0;min-width:0;align-items:center;justify-content:center;flex-wrap:nowrap;gap:0;background-color:transparent;padding:6px 16px;border-radius:2px;">
                @foreach (var item in MenuItems)
                {
                    <div class="lakka-nav-item">
                        <span class="lakka-nav-link">@item.Title</span>

                        <!-- Tam ekran genişliğinde Mega Panel (hover ile görünür) -->
                        <div class="lakka-nav-dropdown">
                            <div class="lakka-nav-dropdown-inner">
                                <!-- SOL: Alt kategori linkleri -->
                                <div class="lakka-nav-dropdown-links">
                                    <div class="lakka-nav-dropdown-title">@item.Title</div>
                                    <div class="lakka-nav-dropdown-list">
                                        @foreach (var sub in item.SubItems)
                                        {
                                            <a href="#" class="lakka-nav-dropdown-link">@sub</a>
                                        }
                                    </div>
                                </div>
                                <!-- SAĞ: Görsel alanı — ImageUrl set edildiğinde otomatik gelir -->
                                <div class="lakka-nav-dropdown-media"
                                     style="@(string.IsNullOrEmpty(item.ImageUrl) ? "" : $"background-image:url('{item.ImageUrl}');")"></div>
                            </div>
                        </div>
                    </div>
                }
            </nav>

            <!-- SAĞ: Arama + Kullanıcı/Sepet -->
            <div style="display:flex;align-items:center;gap:6px;flex-shrink:0;">
                <div style="display:flex;align-items:center;border:1px solid #E5E0D8;background:#FDFBF7;padding:4px 10px;height:36px;">
                    <MudIcon Icon="@Icons.Material.Outlined.Search"
                             Size="Size.Small" Style="color:#6E6E6E;font-size:18px;" />
                    <input type="text" placeholder="Ara..."
                           style="border:none;outline:none;background:transparent;font-family:'Inter',sans-serif;font-size:0.82rem;padding:0 8px;width:170px;color:#2C2C2C;letter-spacing:0.5px;" />
                </div>
                <MudIconButton Icon="@Icons.Material.Outlined.PersonOutline"
                               Color="Color.Inherit" Size="Size.Small" />
                <MudIconButton Icon="@Icons.Material.Outlined.FavoriteBorder"
                               Color="Color.Inherit" Size="Size.Small"
                               Class="d-none d-sm-inline-flex" />
                <MudIconButton Icon="@Icons.Material.Outlined.ShoppingBag"
                               Color="Color.Inherit" Size="Size.Small" />
            </div>
        </div>
    </MudAppBar>

    <MudMainContent Style="background-color:#FDFBF7;min-height:100vh;padding-top:130px;">
        @Body

        <!-- =========================================================
             Bülten Şeridi
        ========================================================== -->
        <div style="background-color:#F3EFEB;padding:70px 24px;margin-top:80px;">
            <div style="max-width:560px;margin:0 auto;text-align:center;">
                <MudText Typo="Typo.h4"
                         Style="font-family:'Cormorant Garamond',serif;color:#1A1A1A;margin-bottom:14px;letter-spacing:0.5px;">
                    Atölyemizden Haberler
                </MudText>
                <MudText Typo="Typo.body2"
                         Style="color:#6E6E6E;line-height:1.8;margin-bottom:28px;">
                    Yeni koleksiyonlar, özel davetler ve zanaatkârlarımızın hikâyeleri için bültenimize katılın.
                </MudText>
                <div style="display:flex;gap:8px;justify-content:center;flex-wrap:wrap;">
                    <MudTextField T="string" Placeholder="E-posta adresiniz"
                                  Variant="Variant.Outlined" Margin="Margin.Dense"
                                  Style="background-color:#FDFBF7;min-width:260px;border-radius:0;" />
                    <MudButton Variant="Variant.Filled" DisableElevation="true"
                               Style="background-color:#2C2C2C;color:#FDFBF7;border-radius:0;padding:10px 28px;letter-spacing:2px;font-size:0.75rem;">
                        Abone Ol
                    </MudButton>
                </div>
            </div>
        </div>

        <!-- =========================================================
             Footer
        ========================================================== -->
        <div style="background-color:#FDFBF7;color:#2C2C2C;padding:80px 24px 32px 24px;border-top:1px solid #E5E0D8;">
            <MudContainer MaxWidth="MaxWidth.ExtraLarge">
                <MudGrid Spacing="6">

                    <MudItem xs="12" md="4">
                        <MudText Typo="Typo.h4"
                                 Style="font-family:'Cormorant Garamond',serif;letter-spacing:10px;font-weight:500;margin-bottom:22px;">
                            LAKKA
                        </MudText>
                        <MudText Typo="Typo.body2" Style="line-height:1.9;color:#6E6E6E;max-width:340px;">
                            Atölyeden yaşam alanınıza uzanan, zamansız ve sofistike bir tasarım yolculuğu. Doğal malzemeler, masif ahşap ve usta el işçiliği.
                        </MudText>
                    </MudItem>

                    <MudItem xs="12" sm="6" md="4">
                        <MudText Typo="Typo.subtitle2"
                                 Style="font-family:'Inter',sans-serif;letter-spacing:2.5px;text-transform:uppercase;font-weight:600;margin-bottom:22px;font-size:0.75rem;">
                            Müşteri Hizmetleri
                        </MudText>
                        <div style="display:flex;flex-direction:column;gap:12px;">
                            <span class="lakka-footer-link" style="font-size:0.88rem;">Sıkça Sorulan Sorular</span>
                            <span class="lakka-footer-link" style="font-size:0.88rem;">Teslimat &amp; İade</span>
                            <span class="lakka-footer-link" style="font-size:0.88rem;">Sipariş Takibi</span>
                            <span class="lakka-footer-link" style="font-size:0.88rem;">Bize Ulaşın</span>
                        </div>
                    </MudItem>

                    <MudItem xs="12" sm="6" md="4">
                        <MudText Typo="Typo.subtitle2"
                                 Style="font-family:'Inter',sans-serif;letter-spacing:2.5px;text-transform:uppercase;font-weight:600;margin-bottom:22px;font-size:0.75rem;">
                            Bizi Takip Edin
                        </MudText>
                        <div style="display:flex;margin-left:-12px;">
                            <MudIconButton Icon="@Icons.Custom.Brands.Instagram" Color="Color.Inherit" />
                            <MudIconButton Icon="@Icons.Custom.Brands.Facebook"  Color="Color.Inherit" />
                            <MudIconButton Icon="@Icons.Custom.Brands.Pinterest" Color="Color.Inherit" />
                        </div>
                    </MudItem>

                </MudGrid>

                <div style="border-top:1px solid #E5E0D8;margin-top:48px;padding-top:24px;text-align:center;">
                    <MudText Typo="Typo.caption" Style="color:#9C9C9C;letter-spacing:1px;">
                        © 2026 LAKKA Mobilya · Tüm Hakları Saklıdır
                    </MudText>
                </div>
            </MudContainer>
        </div>
    </MudMainContent>
</MudLayout>


@code {
    private MudTheme _lakkaTheme = new MudTheme()
    {
        Palette = new PaletteLight()
        {
            Primary          = "#2C2C2C",
            Secondary        = "#A38B70",
            Background       = "#FDFBF7",
            Surface          = "#FDFBF7",
            AppbarBackground = "#958799",
            AppbarText       = "#FFFFFF",
            TextPrimary      = "#2C2C2C",
            TextSecondary    = "#6E6E6E",
            ActionDefault    = "#2C2C2C",
            DrawerBackground = "#FDFBF7",
            LinesDefault     = "#E5E0D8"
        }
    };

    private record NavMenu(string Title, string[] SubItems, bool Highlight = false, string ImageUrl = "");

    // Mega panel sağ bloğuna gelen resimler: wwwroot/images/menu/ klasörüne koyup,
    // aşağıda ilgili menünün ImageUrl alanına "images/menu/dosyaadi.jpg" yaz.
    private readonly List<NavMenu> MenuItems = new()
    {
        new NavMenu("Yeni Ürünler",    new[] { "Bahar 2026 Koleksiyonu", "Yeni Gelen Mobilyalar", "Sınırlı Seri", "Tasarımcı Seçkisi" },                         ImageUrl: ""),
        new NavMenu("Odalar",          new[] { "Oturma Odası", "Yemek Odası", "Yatak Odası", "Çalışma Odası", "Çocuk Odası", "Antre", "Banyo" },                  ImageUrl: ""),
        new NavMenu("Mobilya",         new[] { "Koltuklar", "Berjerler", "Yemek Masaları", "Sandalyeler", "Yatak Bazaları", "Gardıroplar", "Komodinler", "Sehpalar", "TV Üniteleri" }, ImageUrl: ""),
        new NavMenu("Döşeme",          new[] { "Halılar", "Kilimler", "Perdeler", "Tüller", "Kırlentler", "Yatak Örtüleri", "Battaniyeler", "Havlular" },        ImageUrl: ""),
        new NavMenu("Aydınlatma",      new[] { "Avizeler", "Sarkıt Lambalar", "Masa Lambaları", "Yer Lambaları", "Aplikler", "Spot ve Ray" },                    ImageUrl: ""),
        new NavMenu("Ev Dekorasyon",   new[] { "Vazolar", "Aynalar", "Tablolar & Çerçeveler", "Saatler", "Mum & Mumluklar", "Heykelcikler", "Şamdanlar" },       ImageUrl: ""),
        new NavMenu("Bahçe",           new[] { "Bahçe Mobilyaları", "Şezlonglar", "Saksılar & Bitki", "Bahçe Aydınlatma", "Şemsiyeler", "Hamaklar" },            ImageUrl: ""),
        new NavMenu("Satış",           new[] { "İndirimli Mobilya", "İndirimli Dekorasyon", "Outlet Koleksiyon", "Son Adetler" },                                Highlight: true, ImageUrl: ""),
        new NavMenu("Hediyelikler",    new[] { "Hediye Kartı", "Hediyelik Setler", "Özel Paketleme", "Mum & Koku", "Küçük Aksesuarlar" },                        ImageUrl: ""),
        new NavMenu("İkonlar",         new[] { "İkonik Tasarımlar", "Klasikler", "Tasarımcı İmzalı", "Vintage Esinli" },                                          ImageUrl: ""),
        new NavMenu("İlham Kaynakları",new[] { "Blog", "Lookbook", "Stil Rehberi", "Atölye Hikâyeleri", "Mevsim İlhamı" },                                        ImageUrl: "")
    };
}
